{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "redirects": [
    { "source": "/about", "destination": "/en/about", "permanent": true },
    { "source": "/portfolio", "destination": "/en/portfolio", "permanent": true },
    { "source": "/blog", "destination": "/en/blog", "permanent": true },
    { "source": "/blog/:slug", "destination": "/en/blog/:slug", "permanent": true },
    { "source": "/solutions", "destination": "/en/solutions", "permanent": true },
    { "source": "/solutions/:slug", "destination": "/en/solutions/:slug", "permanent": true },
    { "source": "/challenges", "destination": "/en/challenges", "permanent": true },
    { "source": "/challenges/:slug", "destination": "/en/challenges/:slug", "permanent": true },
    { "source": "/press", "destination": "/en/press", "permanent": true },
    { "source": "/researches", "destination": "/en/researches", "permanent": true },
    { "source": "/writing", "destination": "/en/writing", "permanent": true },
    { "source": "/contact", "destination": "/en/#contact", "permanent": true },
    { "source": "/category/:slug", "destination": "/en/blog", "permanent": true },
    { "source": "/category/:slug/", "destination": "/en/blog", "permanent": true }
  ]
}
